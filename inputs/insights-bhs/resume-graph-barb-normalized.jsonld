    "http://schema.org/description": [
      {
        "@value": "Full-stack Data Scientist specializing in generative AI and LLM-powered assistants. I blend deep hands-on modeling and RAG development with a strong sense for product fit and human-centered design. Known for translating complex workflows into intuitive AI capabilities, collaborating closely with engineers and PMs, and iterating through data-driven evaluation and feedback loops. I love building systems that feel helpful, reliable, and genuinely improve how people work."
      }
    ],
