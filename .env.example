# ── Required ──────────────────────────────────────────────────────────────────

# OpenAI API key — used for embeddings (text-embedding-3-small) and LLM completions
OPENAI_API_KEY=sk-...

# ── Optional: Notifications (Pushover) ────────────────────────────────────────
# Barbara is notified via Pushover when visitors flag a knowledge gap or request contact.
# Leave blank to disable notifications silently.
PUSHOVER_USER=
PUSHOVER_TOKEN=

# ── Optional: Model / retrieval tuning ────────────────────────────────────────
# LLM used for completions. Defaults shown; override to switch without code changes.
# app.py default:       gpt-4.1
# app_admin.py default: openai/gpt-4.1  (LiteLLM prefix required for admin app)
LLM_MODEL=gpt-4.1

# Number of KB chunks retrieved per query (default: 10)
N_CHUNKS_RETRIEVE=10

# ── Optional: Server ports ────────────────────────────────────────────────────
PORT=7860        # public app  (app.py)
ADMIN_PORT=7861  # admin app   (app_admin.py)

# ── Optional: HuggingFace Spaces deployment ───────────────────────────────────
# Set automatically by HF Spaces; only needed if deploying manually or testing locally.
HF_TOKEN=hf_...
SPACE_ID=barbhs/barbs-digital-twin
CUSTOM_DOMAIN=twin.barbhs.com
