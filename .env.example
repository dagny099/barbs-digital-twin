# ── Required ──────────────────────────────────────────────────────────────────

# OpenAI API key — used for embeddings (text-embedding-3-small) and LLM completions
OPENAI_API_KEY=sk-...

# ── Optional: Notifications (Pushover) ────────────────────────────────────────
# Barbara is notified via Pushover when visitors flag a knowledge gap or request contact.
# Leave blank to disable notifications silently.
PUSHOVER_USER=
PUSHOVER_TOKEN=

# ── Optional: Model / retrieval tuning ────────────────────────────────────────
# LLM used for completions. Defaults shown; override to switch without code changes.
# When SHOW_SETTINGS_PANEL=true, use provider prefix (e.g., openai/gpt-4.1-mini, anthropic/claude-haiku-3.5)
# Otherwise provider prefix is optional (defaults to openai/)
# app.py default:       gpt-4.1-mini (auto-prefixed to openai/gpt-4.1-mini)
# app_admin.py default: openai/gpt-4.1  (LiteLLM prefix required)
LLM_MODEL=gpt-4.1-mini

# Number of KB chunks retrieved per query (default: 10)
N_CHUNKS_RETRIEVE=5

# LLM temperature: 0 = deterministic, 1 = default model behavior, 0.7 = balanced default
# Applies to app.py, app_admin.py (slider default), and run_evals.py for consistency.
LLM_TEMPERATURE=0.4

# Truncate history to prevent token overflow
# Keep only last N conversation turns (N turns = 2N messages: user + assistant)
# This prevents hitting the 272k token limit on long conversations
MAX_HISTORY_MESSAGES=10

# ── Optional: Chunking tuning (ingest-time only) ──────────────────────────────
# These control how KB documents and web pages are split for embedding.
# Changes only take effect on the NEXT ingest — existing chunks in ChromaDB are
# not retroactively re-chunked. Run `python scripts/ingest.py --all --force`
# after changing these to rebuild the knowledge base.
CHUNK_SIZE=900       # target chunk size in chars (paragraph boundaries are respected)
CHUNK_OVERLAP=100    # overlap between consecutive chunks in chars

# ── Optional: Show settings panel in UI (development only) ────────────────────
# Set to "true" to enable model/temperature/top-k sliders in app.py UI
# Unlocks multi-provider support (OpenAI, Anthropic, Google, Ollama) in app.py
# Default: "false" (hidden in production for clean UI)
SHOW_SETTINGS_PANEL=false

# ── Optional: Additional LLM providers ───────────────────────────────────────
# Required for Anthropic and Google models in app_admin.py (always) and app.py (when SHOW_SETTINGS_PANEL=true)
# Uses LiteLLM for unified multi-provider interface
# Leave blank if only using OpenAI models
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Optional: Server ports ────────────────────────────────────────────────────
PORT=7860        # public app  (app.py)
ADMIN_PORT=7862  # admin app   (app_admin.py)
ADMIN_USER=admin
ADMIN_PASSWORD=

# ── Optional: HuggingFace Spaces deployment ───────────────────────────────────
# Set automatically by HF Spaces; only needed if deploying manually or testing locally.
HF_TOKEN=hf_...
SPACE_ID=
CUSTOM_DOMAIN=
